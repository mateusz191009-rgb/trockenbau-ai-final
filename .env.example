# Supabase-Zugangsdaten (im Supabase-Dashboard unter "Project Settings > API").
# Diese Datei nach .env.local kopieren und Werte eintragen.
NEXT_PUBLIC_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# OpenAI – für die KI-Angebotserstellung (nur serverseitig, niemals im Client).
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Modelle überschreiben (Standardwerte sind kostengünstig gewählt).
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1
